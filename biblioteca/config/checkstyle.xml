<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Reglas de estilo para el proyecto.
    Ejecutar con: mvn checkstyle:check
    Ver reporte en: target/checkstyle-result.xml
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>

    <!-- Verificar archivos Java -->
    <module name="TreeWalker">

        <!-- ===== NOMBRES ===== -->
        <!-- Clases en PascalCase -->
        <module name="TypeName"/>
        <!-- Métodos en camelCase -->
        <module name="MethodName"/>
        <!-- Variables en camelCase -->
        <module name="LocalVariableName"/>
        <!-- Constantes en UPPER_SNAKE_CASE -->
        <module name="ConstantName"/>
        <!-- Parámetros en camelCase -->
        <module name="ParameterName"/>

        <!-- ===== IMPORTS ===== -->
        <!-- Sin imports con comodín (import java.util.*) -->
        <module name="AvoidStarImport"/>
        <!-- Sin imports sin usar -->
        <module name="UnusedImports"/>
        <!-- Sin imports redundantes -->
        <module name="RedundantImport"/>

        <!-- ===== JAVADOC ===== -->
        <!-- Clases públicas deben tener Javadoc -->
        <module name="MissingJavadocType">
            <property name="scope" value="public"/>
        </module>
        <!-- Métodos públicos deben tener Javadoc -->
        <module name="MissingJavadocMethod">
            <property name="scope" value="public"/>
        </module>

        <!-- ===== BUENAS PRÁCTICAS ===== -->
        <!-- Sin bloques catch vacíos -->
        <module name="EmptyCatchBlock"/>
        <!-- Llaves siempre requeridas en if/for/while -->
        <module name="NeedBraces"/>
        <!-- Simplificar booleanos (no "x == true") -->
        <module name="SimplifyBooleanExpression"/>
        <module name="SimplifyBooleanReturn"/>
        <!-- Detectar cadenas de if/else muy largas -->
        <module name="MissingSwitchDefault"/>

        <!-- ===== LONGITUD Y COMPLEJIDAD ===== -->
        <!-- Máximo 30 líneas por método (favorece SRP) -->
        <module name="MethodLength">
            <property name="max" value="30"/>
        </module>
        <!-- Máximo 5 parámetros por método -->
        <module name="ParameterNumber">
            <property name="max" value="5"/>
        </module>

        <!-- ===== ESPACIADO ===== -->
        <!-- Espacios después de comas -->
        <module name="WhitespaceAfter"/>
        <!-- Sin espacios innecesarios al final de línea -->
        <module name="Regexp">
            <property name="format" value="[ \t]+$"/>
            <property name="illegalPattern" value="true"/>
            <property name="message" value="Espacios en blanco al final de línea"/>
        </module>
    </module>

    <!-- Máximo 120 caracteres por línea -->
    <module name="LineLength">
        <property name="max" value="120"/>
    </module>

    <!-- Sin tabs, usar espacios -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>
</module>
